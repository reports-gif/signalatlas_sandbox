<style>
    .sx9{font-family:Verdana,Geneva,Tahoma,sans-serif;color:#0f172a;padding:16px;max-width:1480px;min-width:1020px;margin:0 auto;background:radial-gradient(circle at 8% 0%,rgba(37,99,235,.09),transparent 26%),radial-gradient(circle at 92% 2%,rgba(249,115,22,.10),transparent 24%),linear-gradient(180deg,#f8fafc 0%,#fff 45%,#f8fafc 100%);border-radius:24px}.sx9 *{box-sizing:border-box}@keyframes sx9FadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}@keyframes sx9Bar{from{width:0}}@keyframes sx9Pulse{0%,100%{transform:scale(1);opacity:.84}50%{transform:scale(1.08);opacity:1}}.sx9-shell{display:grid;gap:18px}.sx9-hero{position:relative;overflow:hidden;border:1px solid rgba(226,232,240,.78);border-radius:30px;padding:24px;color:#fff;background:linear-gradient(135deg,#020617 0%,#0f172a 48%,#172554 100%);box-shadow:0 20px 58px rgba(15,23,42,.22);animation:sx9FadeUp .42s ease both}.sx9-hero:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 78% 10%,rgba(37,99,235,.46),transparent 27%),radial-gradient(circle at 96% 76%,rgba(249,115,22,.23),transparent 25%),linear-gradient(120deg,rgba(255,255,255,.09),transparent 32%,transparent 68%,rgba(255,255,255,.05));pointer-events:none}.sx9-hero:after{content:"";position:absolute;width:440px;height:440px;right:-210px;top:-220px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,.52),rgba(59,130,246,0));animation:sx9Pulse 4.8s ease-in-out infinite;pointer-events:none}.sx9-hero-top{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:flex-start;gap:20px}.sx9-kicker{display:inline-flex;align-items:center;gap:8px;padding:7px 11px;border-radius:999px;border:1px solid rgba(147,197,253,.34);background:rgba(37,99,235,.18);color:#bfdbfe;font-size:10px;font-weight:900;letter-spacing:.07em;text-transform:uppercase}.sx9-title{margin:13px 0 8px;font-size:36px;line-height:1.06;letter-spacing:-.045em;font-weight:900}.sx9-sub{margin:0;max-width:910px;color:#cbd5e1;font-size:12px;line-height:1.68}.sx9-actions{position:relative;z-index:2;display:flex;flex-wrap:wrap;justify-content:flex-end;gap:8px;min-width:210px}.sx9-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;min-height:38px;padding:9px 13px;border-radius:13px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.10);color:#fff;text-decoration:none;font-size:11px;font-weight:900;white-space:nowrap;backdrop-filter:blur(10px)}.sx9-btn.primary{background:#2563eb;border-color:#2563eb;box-shadow:0 12px 24px rgba(37,99,235,.28)}.sx9-status-row{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}.sx9-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-size:10px;font-weight:900;border:1px solid transparent;white-space:nowrap}.sx9-ok{background:#ecfdf5;color:#047857;border-color:#a7f3d0}.sx9-bad{background:#fef2f2;color:#b91c1c;border-color:#fecaca}.sx9-warn{background:#fff7ed;color:#9a3412;border-color:#fed7aa}.sx9-muted{background:#f1f5f9;color:#475569;border-color:#e2e8f0}.sx9-blue{background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe}.sx9-metrics{position:relative;z-index:1;display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;margin-top:22px}.sx9-metric{border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.09);border-radius:20px;padding:15px;backdrop-filter:blur(12px);transition:transform .22s ease,background .22s ease;min-height:108px}.sx9-metric:hover{transform:translateY(-3px);background:rgba(255,255,255,.13)}.sx9-label{font-size:10px;color:#bfdbfe;text-transform:uppercase;letter-spacing:.08em;font-weight:900;margin-bottom:8px}.sx9-value{font-size:26px;line-height:1;font-weight:900;letter-spacing:-.04em;color:#fff;word-break:break-word}.sx9-note{margin-top:8px;color:#cbd5e1;font-size:10px;line-height:1.35}.sx9-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:18px}.sx9-card{border:1px solid #e5e7eb;background:rgba(255,255,255,.97);border-radius:24px;box-shadow:0 12px 34px rgba(15,23,42,.07);overflow:hidden;animation:sx9FadeUp .52s ease both;transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease}.sx9-card:hover{transform:translateY(-2px);border-color:#dbeafe;box-shadow:0 18px 44px rgba(15,23,42,.10)}.sx9-card-pad{padding:20px}.sx9-span-4{grid-column:span 4}.sx9-span-5{grid-column:span 5}.sx9-span-6{grid-column:span 6}.sx9-span-7{grid-column:span 7}.sx9-span-8{grid-column:span 8}.sx9-span-12{grid-column:span 12}.sx9-head{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:16px}.sx9-head h3{margin:0;color:#0f172a;font-size:16px;font-weight:900;letter-spacing:-.02em}.sx9-head p{margin:5px 0 0;color:#64748b;font-size:11px;line-height:1.55}.sx9-insight-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.sx9-insight{border:1px solid #e5e7eb;border-radius:18px;background:radial-gradient(circle at 100% 0%,rgba(37,99,235,.06),transparent 32%),#fff;padding:15px;min-height:118px}.sx9-insight-title{color:#64748b;font-size:10px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin-bottom:7px}.sx9-insight-value{font-size:18px;font-weight:900;color:#0f172a;letter-spacing:-.03em}.sx9-insight-copy{margin-top:8px;color:#64748b;font-size:11px;line-height:1.5}.sx9-chart-wrap{display:grid;grid-template-columns:190px 1fr;align-items:center;gap:18px}.sx9-pie{width:178px;height:178px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(#2563eb 0 32%,#22c55e 32% 54%,#f59e0b 54% 74%,#8b5cf6 74% 100%);position:relative;box-shadow:0 18px 36px rgba(15,23,42,.12)}.sx9-pie:after{content:"";position:absolute;width:106px;height:106px;border-radius:50%;background:#fff;box-shadow:inset 0 0 0 1px #e5e7eb}.sx9-pie-center{position:relative;z-index:2;text-align:center}.sx9-pie-center strong{display:block;font-size:23px;color:#0f172a;font-weight:900;line-height:1}.sx9-pie-center span{display:block;margin-top:5px;color:#64748b;font-size:9px;text-transform:uppercase;letter-spacing:.07em;font-weight:900}.sx9-legend{display:grid;gap:9px}.sx9-legend-item{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:9px;padding:10px 12px;border:1px solid #e5e7eb;border-radius:14px;background:#fff;font-size:11px;color:#334155;font-weight:800}.sx9-dot{width:10px;height:10px;border-radius:999px;background:#2563eb}.sx9-dot.green{background:#22c55e}.sx9-dot.orange{background:#f59e0b}.sx9-dot.purple{background:#8b5cf6}.sx9-bars{display:grid;gap:13px}.sx9-bar-row{display:grid;grid-template-columns:160px 1fr auto;align-items:center;gap:10px;font-size:11px;color:#334155;font-weight:800}.sx9-track{height:10px;border-radius:999px;background:#e5e7eb;overflow:hidden}.sx9-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,#2563eb,#60a5fa);animation:sx9Bar .9s ease both}.sx9-fill.green{background:linear-gradient(90deg,#059669,#34d399)}.sx9-fill.orange{background:linear-gradient(90deg,#ea580c,#fdba74)}.sx9-fill.purple{background:linear-gradient(90deg,#7c3aed,#c4b5fd)}.sx9-funnel{display:grid;gap:10px}.sx9-funnel-row{display:grid;grid-template-columns:130px 1fr auto;align-items:center;gap:10px;font-size:11px;font-weight:900;color:#334155}.sx9-funnel-bar{height:24px;border-radius:999px;background:#e5e7eb;overflow:hidden}.sx9-funnel-fill{height:100%;border-radius:999px;display:flex;align-items:center;justify-content:flex-end;padding-right:10px;color:#fff;font-size:10px;font-weight:900;background:linear-gradient(90deg,#2563eb,#60a5fa);animation:sx9Bar 1s ease both}.sx9-table-wrap{width:100%;overflow:auto;border-top:1px solid #e5e7eb;max-height:440px}.sx9-table{width:100%;min-width:900px;border-collapse:collapse;font-size:12px}.sx9-table th{position:sticky;top:0;z-index:2;background:#f8fafc;color:#475569;text-align:left;padding:13px 16px;border-bottom:1px solid #e5e7eb;font-size:10px;text-transform:uppercase;letter-spacing:.08em;font-weight:900;white-space:nowrap}.sx9-table td{padding:14px 16px;border-bottom:1px solid #f1f5f9;color:#334155;vertical-align:top}.sx9-table tr:hover td{background:#f8fafc}.sx9-link{color:#1d4ed8;font-weight:900;text-decoration:none}.sx9-link:hover{text-decoration:underline}.sx9-code{font-family:Verdana,Geneva,Tahoma,sans-serif;font-size:11px;color:#475569;word-break:break-all}.sx9-tag{display:inline-flex;align-items:center;padding:5px 9px;border-radius:999px;font-size:10px;font-weight:900;background:#f1f5f9;color:#475569;white-space:nowrap}.sx9-action-grid{display:grid;gap:10px}.sx9-action{border:1px solid #fed7aa;background:linear-gradient(135deg,#fff7ed,#fffbeb);color:#9a3412;border-radius:16px;padding:13px 15px;font-size:11px;line-height:1.48;font-weight:800}.sx9-footer{color:#64748b;font-size:11px;line-height:1.55;background:#f8fafc;border:1px solid #e5e7eb;border-radius:18px;padding:14px}.sx9-alert{border:1px solid #fed7aa;background:linear-gradient(135deg,#fff7ed,#fffbeb);color:#9a3412;border-radius:16px;padding:13px 15px;font-size:12px;line-height:1.45;font-weight:800}.sx9-alert.error{background:#fef2f2;border-color:#fecaca;color:#991b1b}@media(max-width:1180px){.sx9{min-width:0}.sx9-metrics{grid-template-columns:repeat(2,minmax(0,1fr))}.sx9-span-4,.sx9-span-5,.sx9-span-6,.sx9-span-7,.sx9-span-8,.sx9-span-12{grid-column:span 12}.sx9-chart-wrap{grid-template-columns:1fr}.sx9-pie{margin:auto}.sx9-insight-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:720px){.sx9{padding:14px}.sx9-hero-top{flex-direction:column}.sx9-metrics,.sx9-insight-grid{grid-template-columns:1fr}.sx9-bar-row,.sx9-funnel-row{grid-template-columns:1fr}}
</style>

<div class="sx9">
    <div class="sx9-shell">
        <div class="sx9-hero">
            <div class="sx9-hero-top">
                <div>
                    <div class="sx9-kicker">HubSpot × SignalAtlas Revenue Command Center</div>
                    <h2 class="sx9-title">SignalAtlas Revenue Intelligence</h2>
                    <p class="sx9-sub">Executive dashboard for high-intent accounts, source-to-revenue attribution, top intent pages, CRM data quality, and HubSpot pipeline visibility. Keep this widget in a full-width dashboard row for the best enterprise view.</p>
                </div>
                <div class="sx9-actions">
                    <a class="sx9-btn primary" href="{{ refreshUrl }}">Refresh now</a>
                    <a class="sx9-btn" href="javascript:void(0)">Read-only mode</a>
                </div>
            </div>

            <div class="sx9-status-row">
                {% if connection.connected %}<span class="sx9-pill sx9-ok">● HubSpot Connected</span>{% else %}<span class="sx9-pill sx9-bad">● HubSpot Error: {{ connection.message }}</span>{% endif %}
                {% if fromCache %}<span class="sx9-pill sx9-muted">Cached result</span>{% else %}<span class="sx9-pill sx9-muted">Live refresh</span>{% endif %}
                <span class="sx9-pill sx9-muted">Generated: {{ generatedAt|default('Live refresh') }}</span>
                <span class="sx9-pill sx9-blue">Attribution coverage: {{ attributionCoverage|default(0) }}%</span>
            </div>

            <div class="sx9-metrics">
                <div class="sx9-metric"><div class="sx9-label">MQL Contacts</div><div class="sx9-value">{{ mqlCount|default(0) }}</div><div class="sx9-note">Fetched {{ mqlFetched|default(0) }}{% if mqlTruncated %}; truncated{% endif %}</div></div>
                <div class="sx9-metric"><div class="sx9-label">SQL Contacts</div><div class="sx9-value">{{ sqlCount|default(0) }}</div><div class="sx9-note">Fetched {{ sqlFetched|default(0) }}{% if sqlTruncated %}; truncated{% endif %}</div></div>
                <div class="sx9-metric"><div class="sx9-label">Hot Accounts</div><div class="sx9-value">{{ highIntentAccountsCount|default(0) }}</div><div class="sx9-note">Accounts scoring 70+ intent</div></div>
                <div class="sx9-metric"><div class="sx9-label">Opportunities</div><div class="sx9-value">{{ opportunityCount|default(0) }}</div><div class="sx9-note">Fetched {{ dealsFetched|default(0) }}{% if dealsTruncated %}; truncated{% endif %}</div></div>
                <div class="sx9-metric"><div class="sx9-label">Closed-won Revenue</div><div class="sx9-value">{{ revenue|number_format(0, '.', ',') }}</div><div class="sx9-note">Closed-won deals: {{ closedWonDeals|default(0) }}</div></div>
                <div class="sx9-metric"><div class="sx9-label">Companies</div><div class="sx9-value">{{ hubspotCompanyCount|default(0) }}</div><div class="sx9-note">Fetched {{ companiesFetched|default(0) }}{% if companiesTruncated %}; truncated{% endif %}</div></div>
            </div>
        </div>

        {% if errors.mql or errors.sql or errors.deals or errors.companies %}<div class="sx9-alert error"><strong>API warning:</strong> {{ errors.mql }} {{ errors.sql }} {{ errors.deals }} {{ errors.companies }}</div>{% endif %}

        <div class="sx9-grid">
            <div class="sx9-card sx9-span-12"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Executive Summary</h3><p>Leadership-ready view of CRM progress, pipeline visibility, attribution maturity, and buyer intent quality.</p></div><span class="sx9-pill sx9-muted">Board View</span></div><div class="sx9-insight-grid"><div class="sx9-insight"><div class="sx9-insight-title">Lead stage visibility</div><div class="sx9-insight-value">{{ mqlCount|default(0) }} MQL / {{ sqlCount|default(0) }} SQL</div><div class="sx9-insight-copy">Validates whether marketing-qualified contacts are moving into sales-owned records.</div></div><div class="sx9-insight"><div class="sx9-insight-title">Hot account coverage</div><div class="sx9-insight-value">{{ highIntentAccountsCount|default(0) }} accounts</div><div class="sx9-insight-copy">Accounts with stronger CRM/source/deal evidence should be prioritized first.</div></div><div class="sx9-insight"><div class="sx9-insight-title">Revenue proof</div><div class="sx9-insight-value">{{ revenue|number_format(0, '.', ',') }}</div><div class="sx9-insight-copy">Closed-won revenue gives leadership a quick read on proven impact.</div></div><div class="sx9-insight"><div class="sx9-insight-title">Attribution coverage</div><div class="sx9-insight-value">{{ attributionCoverage|default(0) }}%</div><div class="sx9-insight-copy">Coverage improves when source, UTM, and Matomo visitor ID are populated.</div></div></div></div></div>

            <div class="sx9-card sx9-span-4"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Journey Mix</h3><p>Evidence split for HubSpot-to-revenue layer.</p></div><span class="sx9-pill sx9-blue">Pie</span></div><div class="sx9-chart-wrap"><div class="sx9-pie"><div class="sx9-pie-center"><strong>{{ mqlCount|default(0) + sqlCount|default(0) }}</strong><span>Total leads</span></div></div><div class="sx9-legend"><div class="sx9-legend-item"><span class="sx9-dot"></span><span>MQL</span><strong>{{ mqlCount|default(0) }}</strong></div><div class="sx9-legend-item"><span class="sx9-dot green"></span><span>SQL</span><strong>{{ sqlCount|default(0) }}</strong></div><div class="sx9-legend-item"><span class="sx9-dot orange"></span><span>Hot accounts</span><strong>{{ highIntentAccountsCount|default(0) }}</strong></div><div class="sx9-legend-item"><span class="sx9-dot purple"></span><span>Closed-won</span><strong>{{ closedWonDeals|default(0) }}</strong></div></div></div></div></div>

            <div class="sx9-card sx9-span-4"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Lifecycle Funnel</h3><p>Simple conversion shape from MQL to revenue proof.</p></div><span class="sx9-pill sx9-ok">Funnel</span></div><div class="sx9-funnel"><div class="sx9-funnel-row"><span>MQL</span><div class="sx9-funnel-bar"><div class="sx9-funnel-fill" style="width:100%">{{ mqlCount|default(0) }}</div></div><strong>Base</strong></div><div class="sx9-funnel-row"><span>SQL</span><div class="sx9-funnel-bar"><div class="sx9-funnel-fill" style="width:{% if mqlCount|default(0) > 0 %}{{ ((sqlCount|default(0) / mqlCount|default(1)) * 100)|round(0, 'floor') }}{% else %}40{% endif %}%">{{ sqlCount|default(0) }}</div></div><strong>Qualified</strong></div><div class="sx9-funnel-row"><span>Opportunities</span><div class="sx9-funnel-bar"><div class="sx9-funnel-fill" style="width:{% if sqlCount|default(0) > 0 %}{{ ((opportunityCount|default(0) / sqlCount|default(1)) * 100)|round(0, 'floor') }}{% else %}20{% endif %}%">{{ opportunityCount|default(0) }}</div></div><strong>Pipeline</strong></div><div class="sx9-funnel-row"><span>Won</span><div class="sx9-funnel-bar"><div class="sx9-funnel-fill" style="width:{% if opportunityCount|default(0) > 0 %}{{ ((closedWonDeals|default(0) / opportunityCount|default(1)) * 100)|round(0, 'floor') }}{% else %}10{% endif %}%">{{ closedWonDeals|default(0) }}</div></div><strong>Revenue</strong></div></div></div></div>

            <div class="sx9-card sx9-span-4"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Data Readiness</h3><p>Visibility health for CRM and attribution evidence.</p></div><span class="sx9-pill sx9-ok">Safe Mode</span></div><div class="sx9-bars"><div class="sx9-bar-row"><span>HubSpot</span><div class="sx9-track"><div class="sx9-fill green" style="width:{% if connection.connected %}100{% else %}10{% endif %}%"></div></div><strong>{% if connection.connected %}Connected{% else %}Issue{% endif %}</strong></div><div class="sx9-bar-row"><span>Attribution</span><div class="sx9-track"><div class="sx9-fill" style="width:{{ attributionCoverage|default(0) }}%"></div></div><strong>{{ attributionCoverage|default(0) }}%</strong></div><div class="sx9-bar-row"><span>Deals</span><div class="sx9-track"><div class="sx9-fill purple" style="width:{% if opportunityCount|default(0) > 0 %}78{% else %}14{% endif %}%"></div></div><strong>{{ opportunityCount|default(0) }}</strong></div><div class="sx9-bar-row"><span>Companies</span><div class="sx9-track"><div class="sx9-fill orange" style="width:{% if hubspotCompanyCount|default(0) > 0 %}82{% else %}12{% endif %}%"></div></div><strong>{{ hubspotCompanyCount|default(0) }}</strong></div></div></div></div>

            <div class="sx9-card sx9-span-8"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Hot Accounts / Buyer Intent</h3><p>Ranked account list based on lifecycle, source evidence, SignalAtlas mapping, and deal signals.</p></div><span class="sx9-pill sx9-blue">Account Scoring</span></div></div><div class="sx9-table-wrap"><table class="sx9-table"><thead><tr><th>Account</th><th>Score</th><th>Stage</th><th>MQL</th><th>SQL</th><th>Deals</th><th>Reason</th><th>Action</th></tr></thead><tbody>{% for row in hotAccounts %}<tr><td><strong>{{ row.company }}</strong><br><span class="sx9-code">{{ row.source }}</span></td><td><span class="sx9-tag">{{ row.score }}</span></td><td><span class="sx9-tag">{{ row.stage }}</span></td><td>{{ row.mql }}</td><td>{{ row.sql }}</td><td>{{ row.dealSignals }}</td><td>{{ row.reason }}</td><td><a class="sx9-link" href="{{ row.journeyUrl }}">Open journey</a></td></tr>{% else %}<tr><td colspan="8">No hot account records available.</td></tr>{% endfor %}</tbody></table></div></div>

            <div class="sx9-card sx9-span-4"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Next Best Actions</h3><p>Auto-prioritized actions for sales and attribution governance.</p></div><span class="sx9-pill sx9-warn">Action Plan</span></div><div class="sx9-action-grid">{% for action in nextActions %}<div class="sx9-action"><strong>{{ action.priority }}: {{ action.title }}</strong><br>{{ action.detail }}</div>{% else %}<div class="sx9-action"><strong>Action plan unavailable.</strong><br>Refresh dashboard after HubSpot connection is confirmed.</div>{% endfor %}</div></div></div>

            <div class="sx9-card sx9-span-6"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Source-to-Revenue Attribution</h3><p>Channel/source performance based on HubSpot lifecycle and deal-linked signals.</p></div><span class="sx9-pill sx9-muted">Source View</span></div></div><div class="sx9-table-wrap"><table class="sx9-table"><thead><tr><th>Source</th><th>Contacts</th><th>MQL</th><th>SQL</th><th>Deal-linked</th><th>SQL Rate</th><th>Avg Score</th></tr></thead><tbody>{% for row in sourceRows %}<tr><td><strong>{{ row.source }}</strong></td><td>{{ row.contacts }}</td><td>{{ row.mql }}</td><td>{{ row.sql }}</td><td>{{ row.dealLinked }}</td><td>{{ row.sqlRate }}%</td><td><span class="sx9-tag">{{ row.avgScore }}</span></td></tr>{% else %}<tr><td colspan="7">No source attribution records available.</td></tr>{% endfor %}</tbody></table></div></div>

            <div class="sx9-card sx9-span-6"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Top Intent Pages</h3><p>SignalAtlas/custom page evidence connected to HubSpot contacts.</p></div><span class="sx9-pill sx9-muted">Page Impact</span></div></div><div class="sx9-table-wrap"><table class="sx9-table"><thead><tr><th>Page / Conversion</th><th>Contacts</th><th>SQL</th><th>Deal-linked</th></tr></thead><tbody>{% for row in topPageRows %}<tr><td class="sx9-code">{{ row.page }}</td><td>{{ row.contacts }}</td><td>{{ row.sql }}</td><td>{{ row.dealLinked }}</td></tr>{% else %}<tr><td colspan="4">No SignalAtlas page evidence is populated yet.</td></tr>{% endfor %}</tbody></table></div></div>

            <div class="sx9-card sx9-span-5"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>CRM Data Quality Gaps</h3><p>Governance gaps blocking clean website-to-revenue attribution.</p></div><span class="sx9-pill sx9-warn">Governance</span></div><div class="sx9-bars"><div class="sx9-bar-row"><span>Missing company</span><div class="sx9-track"><div class="sx9-fill orange" style="width:{% if dataQuality.totalContacts > 0 %}{{ ((dataQuality.missingCompany / dataQuality.totalContacts) * 100)|round(0, 'floor') }}{% else %}0{% endif %}%"></div></div><strong>{{ dataQuality.missingCompany }}</strong></div><div class="sx9-bar-row"><span>Missing source</span><div class="sx9-track"><div class="sx9-fill orange" style="width:{% if dataQuality.totalContacts > 0 %}{{ ((dataQuality.missingSource / dataQuality.totalContacts) * 100)|round(0, 'floor') }}{% else %}0{% endif %}%"></div></div><strong>{{ dataQuality.missingSource }}</strong></div><div class="sx9-bar-row"><span>Missing UTM</span><div class="sx9-track"><div class="sx9-fill orange" style="width:{% if dataQuality.totalContacts > 0 %}{{ ((dataQuality.missingUtm / dataQuality.totalContacts) * 100)|round(0, 'floor') }}{% else %}0{% endif %}%"></div></div><strong>{{ dataQuality.missingUtm }}</strong></div><div class="sx9-bar-row"><span>No visitor ID</span><div class="sx9-track"><div class="sx9-fill orange" style="width:{% if dataQuality.totalContacts > 0 %}{{ ((dataQuality.missingMatomo / dataQuality.totalContacts) * 100)|round(0, 'floor') }}{% else %}0{% endif %}%"></div></div><strong>{{ dataQuality.missingMatomo }}</strong></div></div></div></div>

            <div class="sx9-card sx9-span-7"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>Attribution Evidence Records</h3><p>MQL/SQL contacts with available HubSpot and SignalAtlas evidence. Click email to open full contact journey.</p></div><span class="sx9-pill sx9-blue">Journey Links</span></div></div><div class="sx9-table-wrap"><table class="sx9-table"><thead><tr><th>Email</th><th>Name</th><th>Company</th><th>Lifecycle</th><th>Source</th><th>Score</th></tr></thead><tbody>{% for row in exampleRows %}<tr><td><a class="sx9-link" href="{{ row.journeyUrl }}">{{ row.email }}</a></td><td>{{ row.name }}</td><td>{{ row.company }}</td><td><span class="sx9-tag">{{ row.lifecycle }}</span></td><td>{{ row.source }}</td><td><span class="sx9-tag">{{ row.score }}</span></td></tr>{% else %}<tr><td colspan="6">No attribution evidence records available.</td></tr>{% endfor %}</tbody></table></div></div>

            <div class="sx9-card sx9-span-12"><div class="sx9-card-pad"><div class="sx9-head"><div><h3>HubSpot Company Records</h3><p>Companies with domains available through HubSpot Companies API.</p></div><span class="sx9-pill sx9-muted">{{ hubspotCompanyCount|default(0) }} Companies</span></div></div><div class="sx9-table-wrap"><table class="sx9-table"><thead><tr><th>Company</th><th>Domain</th><th>Industry</th><th>Employees</th><th>Lifecycle</th><th>Last Modified</th></tr></thead><tbody>{% for company in hubspotCompanies %}{% set cp = company.properties|default({}) %}<tr><td>{{ attribute(cp, 'name')|default('Not captured') }}</td><td class="sx9-code">{{ attribute(cp, 'domain')|default('Not captured') }}</td><td>{{ attribute(cp, 'industry')|default('Not captured') }}</td><td>{{ attribute(cp, 'numberofemployees')|default('Not captured') }}</td><td><span class="sx9-tag">{{ attribute(cp, 'lifecyclestage')|default('Not captured') }}</span></td><td>{{ attribute(cp, 'hs_lastmodifieddate')|default('Not captured') }}</td></tr>{% else %}<tr><td colspan="6">No HubSpot company records available.</td></tr>{% endfor %}</tbody></table></div></div>

            <div class="sx9-card sx9-span-12"><div class="sx9-card-pad"><div class="sx9-footer"><strong>Evidence note:</strong> HubSpot counts come from read-only Contacts, Deals, and Companies APIs. SignalAtlas rows should be treated as attribution evidence only when visitor ID, UTM, landing page, and email mapping are populated. Account scoring is directional and designed for prioritization, not financial reporting.</div></div></div>
        </div>
    </div>
</div>
